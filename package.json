{
  "name": "shaktimaanai",
  "version": "0.1.0",
  "description": "Agentic development pipeline — automates research, design, TDD implementation, review, and PR creation",
  "type": "module",
  "bin": {
    "shkmn": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-agents.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agent",
    "pipeline",
    "claude",
    "development",
    "automation"
  ],
  "author": "Pratyush Pande",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prpande/ShaktimaanAI.git"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@clack/prompts": "^1.2.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.2"
  }
}
